#!/usr/bin/env bash
#
# grandma — the terminal that remembers you.
#
# A sweater is a part of your life you keep memory under: a company, a client, a
# platform like reddit, an area like job-search. Under a sweater live your projects.
#
# Usage:
#   grandma                            meet grandma / pick a sweater / knit a new one
#   grandma <sweater> [project] [task] launch a session with that sweater's memory
#   grandma init                       first-run setup (memory home, PATH, interview)
#   grandma save <sweater> [project]   distill a finished session into memory
#   grandma review [sweater]           review auto-distill proposals
#   grandma search [sweater] <query>   grep across your memory
#   grandma ingest [sweater] [--root]  catalog a folder of projects into a sweater
#   grandma watch <start|status|...>   analysis campaigns over your sessions
#   grandma test [sweater]             verify the context-integrity invariants
#   grandma doctor                     check dependencies and memory-home health
#   grandma completions <bash|zsh>     print the shell tab-completion script
#   grandma update                     fast-forward the engine to the latest master
#   grandma version                    print the running engine version
#   grandma help                       this text
#
# Memory lives in GRANDMA_HOME (default ~/.grandma) — your files, your git repo,
# never this engine's. Sweater names that collide with subcommands above are reserved.

set -uo pipefail
ENGINE="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

sub="${1:-}"
case "$sub" in
  init|doctor)  shift; exec "$ENGINE/lib/grandma-init.sh" "$sub" "$@" ;;
  save)         shift; exec "$ENGINE/lib/grandma-save.sh" "$@" ;;
  review)       shift; exec "$ENGINE/lib/grandma-review.sh" "$@" ;;
  search)       shift; exec "$ENGINE/lib/grandma-search.sh" "$@" ;;
  ingest)       shift; exec "$ENGINE/lib/grandma-ingest.sh" "$@" ;;
  watch)        shift; exec "$ENGINE/lib/grandma-watch.sh" "$@" ;;
  test)         shift; exec "$ENGINE/lib/grandma-test.sh" "$@" ;;
  completions)  shift; exec "$ENGINE/lib/grandma-completions.sh" "$@" ;;
  update)       shift; exec "$ENGINE/lib/grandma-update.sh" "$@" ;;
  version|--version|-v) exec "$ENGINE/lib/grandma-update.sh" version ;;
  help|-h|--help) sed -n '3,25p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'; exit 0 ;;
  *)            exec "$ENGINE/lib/grandma-launch.sh" "$@" ;;
esac
